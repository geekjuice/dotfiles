{
  "name": "grove",
  "version": "0.1.0",
  "description": "Local git worktree management TUI - privacy-focused alternative to Conductor.build",
  "type": "module",
  "bin": {
    "grove": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node --import tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --dts",
    "compile": "bun build src/cli.tsx --compile --outfile grove",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.2.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "simple-git": "^3.27.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
